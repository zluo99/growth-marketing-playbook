# Public site URL for metadata and canonical links (overrides VERCEL_URL when set)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Automatically injected by Vercel at build/runtime — no need to set locally.
# Used as fallback for metadataBase when NEXT_PUBLIC_SITE_URL is absent.
# VERCEL_URL=your-deployment.vercel.app
